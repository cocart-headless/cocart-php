{
    "name": "cocart-headless/cocart-php",
    "description": "CoCart's Official PHP SDK",
    "keywords": [
        "cocart",
        "woocommerce",
        "cart",
        "rest-api",
        "sdk",
        "headless",
        "ecommerce"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "CoCart Headless, LLC",
            "email": "support@cocartheadless.com"
        }
    ],
    "homepage": "https://cocartapi.com",
    "support": {
        "issues": "https://github.com/cocart-headless/cocart-php/issues",
        "source": "https://github.com/cocart-headless/cocart-php"
    },
    "require": {
        "php": ">=8.2",
        "ext-json": "*"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Recommended HTTP client for best performance (^7.0)"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "CoCart\\": "src/"
        },
        "files": [
            "src/CoCart.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "CoCart\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
